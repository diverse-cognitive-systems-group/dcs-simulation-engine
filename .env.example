# DCS GROUP .env POLICY
# .env files are generated and distributed by DCS admins only
# Never share your .env file or API keys with anyone
# Admins will transfer keys to you once; do not redistribute them
# If you run out of credits, contact a DCS admin
# API keys are issued per person and/or per repository to track usage
 
# mongodb host uri
MONGO_URI=mongodb://0.0.0.0:27017/

# Enable free play mode (no authentication, no rate limits) for local development and testing
# set to 0 for testing auth
DCS_FREE_PLAY=1

# !!! YOU MUST SET OPENROUTER_API_KEY IR IT WONT WORK !!!
# OPENROUTER_API_KEY=sk-...  # Your OpenRouter API key here
# FLY_API_TOKEN=...  # Your Fly.io API token here
# DCS_ADMIN_KEY=dcs-ak-...  # Generated by admin at deployment time; used by `dcs remote` commands