{
    "mypy-type-checker.ignorePatterns": [
        "**/**/*.py",
    ],
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.profiles.linux": {
        "zsh": {
            "path": "/bin/zsh",
            "args": [
                "-l", // login shell
                "-i"  // interactive shell
            ]
        }
    },
    "evenBetterToml.formatter.reorderKeys": true,
}
