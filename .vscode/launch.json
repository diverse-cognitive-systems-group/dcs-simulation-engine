{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "pytest",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest: functional",
            "args": [
                "-m",
                "functional",
                "-v",
            ],
            "cwd": "${workspaceFolder}",
        },
        {
            "name": "dcs list game",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dcs_simulation_engine/cli/app.py",
            "args": [
                "list",
                "games",
            ],
            "cwd": "${workspaceFolder}",
            // run docker compose in dev with: docker compose -f docker-compose.dev.yaml up --build
            "preLaunchTask": "docker-compose-up",
            "postDebugTask": "docker-compose-down",
        },
        {
            "name": "dcs server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dcs_simulation_engine/cli/app.py",
            "args": [
                "server",
                "--mongo-seed-dir=database_seeds/dev",
            ],
            "cwd": "${workspaceFolder}",
            // run docker compose in dev with: docker compose -f docker-compose.dev.yaml up --build
            "preLaunchTask": "docker-compose-up",
            "postDebugTask": "docker-compose-down",
            "env": {
                "DEBUGPY_PROCESS_SPAWN_TIMEOUT": "5" // Timeout in seconds (90 seconds)
            }
        },
        {
            "name": "dcs server freeplay",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dcs_simulation_engine/cli/app.py",
            "args": [
                "server",
                "--mongo-seed-dir=database_seeds/dev",
                "--free-play",
            ],
            "cwd": "${workspaceFolder}",
            // run docker compose in dev with: docker compose -f docker-compose.dev.yaml up --build
            "preLaunchTask": "docker-compose-up",
            "postDebugTask": "docker-compose-down",
            "env": {
                "DEBUGPY_PROCESS_SPAWN_TIMEOUT": "5" // Timeout in seconds (90 seconds)
            }
        },
        {
            "name": "dcs create database: dev",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/dcs_simulation_engine/cli/app.py",
            "args": [
                "create",
                "database",
                "--path",
                "database_seeds/dev",
            ],
            "cwd": "${workspaceFolder}",
            // run docker compose in dev with: docker compose -f docker-compose.dev.yaml up --build
            "preLaunchTask": "docker-compose-up",
            "postDebugTask": "docker-compose-down",
        }
    ]
}